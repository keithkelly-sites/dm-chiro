---
import Layout from '../layouts/Layout.astro';

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "D & M Chiropractic and Therapeutic Rehab, Inc.",
  "telephone": "(412) 833-1101",
  "faxNumber": "(412) 833-1075",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "2589 Washington Road, Suite 410",
    "addressLocality": "Upper St. Clair",
    "addressRegion": "PA",
    "postalCode": "15241",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.3304,
    "longitude": -80.0534
  },
  "openingHoursSpecification": [
    {"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Wednesday","Friday"],"opens":"08:00","closes":"12:30"},
    {"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Wednesday","Friday"],"opens":"14:00","closes":"18:00"}
  ]
};
---
<Layout
  title="Contact | D & M Chiropractic — Upper St. Clair, PA"
  description="Contact D & M Chiropractic and Therapeutic Rehab in Upper St. Clair, PA. Call (412) 833-1101 or request your free consultation online. Located at 2589 Washington Road, Suite 410."
  canonicalPath="/contact/"
  schema={contactSchema}
  page="contact"
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="page-hero-bg" aria-hidden="true"></div>
    <div class="container page-hero-content">
      <span class="section-label reveal">Get In Touch</span>
      <h1 class="page-hero-heading reveal reveal-delay-1">Start Your Journey<br/><span class="teal-text">To Pain-Free Living</span></h1>
      <p class="page-hero-sub reveal reveal-delay-2">New patients receive a <strong>FREE consultation + FREE MRI review</strong> — a $247 value. No obligation. Most insurance accepted.</p>
    </div>
  </section>

  <section class="section contact-section" aria-labelledby="contact-heading">
    <div class="container contact-layout">

      <!-- Form -->
      <div class="contact-form-wrap reveal" id="contact-heading">
        <h2 class="contact-form-heading">Request an Appointment</h2>
        <p class="contact-form-sub">Fill out the form and we'll contact you to confirm your appointment — usually within one business day.</p>

        <form class="contact-form" action="#" method="POST" novalidate aria-label="Appointment request form">
          <div class="form-row">
            <div class="form-group">
              <label for="first-name" class="form-label">First Name <span class="required" aria-hidden="true">*</span></label>
              <input type="text" id="first-name" name="first_name" class="form-input" placeholder="Jane" required autocomplete="given-name" />
            </div>
            <div class="form-group">
              <label for="last-name" class="form-label">Last Name <span class="required" aria-hidden="true">*</span></label>
              <input type="text" id="last-name" name="last_name" class="form-input" placeholder="Smith" required autocomplete="family-name" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="phone" class="form-label">Phone <span class="required" aria-hidden="true">*</span></label>
              <input type="tel" id="phone" name="phone" class="form-input" placeholder="(412) 555-0100" required autocomplete="tel" />
            </div>
            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <input type="email" id="email" name="email" class="form-input" placeholder="jane@example.com" autocomplete="email" />
            </div>
          </div>

          <div class="form-group">
            <label for="concern" class="form-label">Primary Concern</label>
            <select id="concern" name="concern" class="form-input form-select">
              <option value="">Select your main concern…</option>
              <option value="back-pain">Back Pain</option>
              <option value="neck-pain">Neck Pain</option>
              <option value="headaches">Headaches / Migraines</option>
              <option value="auto-injury">Auto Accident Injury</option>
              <option value="work-injury">Work Injury</option>
              <option value="disc">Bulging / Herniated Disc</option>
              <option value="pediatric">Pediatric Care</option>
              <option value="wellness">General Wellness</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message" class="form-label">Additional Information</label>
            <textarea id="message" name="message" class="form-input form-textarea" placeholder="Tell us about your symptoms, how long you've had them, and any previous treatments…" rows="4"></textarea>
          </div>

          <div class="form-group form-check-group">
            <label class="form-check">
              <input type="checkbox" name="new_patient" value="yes" class="form-checkbox" />
              <span>I am a new patient</span>
            </label>
            <label class="form-check">
              <input type="checkbox" name="has_mri" value="yes" class="form-checkbox" />
              <span>I have an existing MRI (free review)</span>
            </label>
          </div>

          <button type="submit" class="btn btn-primary form-submit">
            Request Free Consultation →
          </button>
          <p class="form-note">We respect your privacy and will never share your information.</p>
        </form>
      </div>

      <!-- Info -->
      <aside class="contact-info reveal reveal-delay-2" aria-label="Office information">
        <!-- Contact details -->
        <div class="info-card card">
          <h3 class="info-heading">Office Information</h3>
          <div class="info-items">
            <div class="info-item">
              <div class="info-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1h3a2 2 0 012 1.72c.12.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L6.09 8.9a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.58 2.81.7A2 2 0 0122 16.92z"/></svg>
              </div>
              <div class="info-content">
                <strong>Phone</strong>
                <a href="tel:+14128331101">(412) 833-1101</a>
                <span>Fax: (412) 833-1075</span>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="info-content">
                <strong>Address</strong>
                <address style="font-style:normal">
                  2589 Washington Road<br/>
                  Suite 410<br/>
                  Upper St. Clair, PA 15241
                </address>
                <a href="https://maps.google.com/?q=2589+Washington+Road+Suite+410+Upper+St+Clair+PA+15241" target="_blank" rel="noopener noreferrer" class="directions-link">
                  Get directions →
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Hours -->
        <div class="info-card card">
          <h3 class="info-heading">Office Hours</h3>
          <ul class="hours-list" aria-label="Office hours">
            <li class="hours-item open">
              <span class="hours-day">Monday</span>
              <span class="hours-time">8:00am – 12:30pm<br/>2:00pm – 6:00pm</span>
            </li>
            <li class="hours-item closed">
              <span class="hours-day">Tuesday</span>
              <span class="hours-closed-label">Closed</span>
            </li>
            <li class="hours-item open">
              <span class="hours-day">Wednesday</span>
              <span class="hours-time">8:00am – 12:30pm<br/>2:00pm – 6:00pm</span>
            </li>
            <li class="hours-item closed">
              <span class="hours-day">Thursday</span>
              <span class="hours-closed-label">Closed</span>
            </li>
            <li class="hours-item open">
              <span class="hours-day">Friday</span>
              <span class="hours-time">8:00am – 12:30pm<br/>2:00pm – 6:00pm</span>
            </li>
            <li class="hours-item closed">
              <span class="hours-day">Saturday</span>
              <span class="hours-closed-label">Closed</span>
            </li>
            <li class="hours-item closed">
              <span class="hours-day">Sunday</span>
              <span class="hours-closed-label">Closed</span>
            </li>
          </ul>
        </div>

        <!-- Free offer reminder -->
        <div class="offer-reminder">
          <div class="offer-reminder-inner">
            <div class="offer-reminder-badge" aria-hidden="true">FREE</div>
            <div>
              <strong>Free Consultation + MRI Review</strong>
              <p>A $247 value for new patients — at no charge.</p>
            </div>
          </div>
        </div>

        <!-- Insurance -->
        <div class="insurance-note card">
          <h3 class="insurance-heading">Insurance Accepted</h3>
          <p>We accept most major insurance plans and handle all the paperwork for you. Please call us to verify your specific coverage.</p>
          <a href="tel:+14128331101" class="btn btn-outline" style="margin-top:1rem;padding:0.625rem 1.25rem;font-size:0.875rem;">Call to Verify Coverage</a>
        </div>
      </aside>

    </div>

    <!-- Map -->
    <div class="map-section container reveal" aria-label="Office location map">
      <h3 class="map-heading">Find Us</h3>
      <div class="map-wrapper">
        <img
          src="/images/map.svg"
          alt="Map showing D&M Chiropractic location at 2589 Washington Road, Suite 410, Upper St. Clair, PA"
          class="map-img"
          width="800"
          height="400"
          loading="lazy"
        />
        <a
          href="https://maps.google.com/?q=2589+Washington+Road+Suite+410+Upper+St+Clair+PA+15241"
          target="_blank"
          rel="noopener noreferrer"
          class="map-open-link"
          aria-label="Open in Google Maps"
        >
          Open in Google Maps →
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    position: relative;
    padding: 8rem 1.5rem 5rem;
    background: var(--navy-dark);
    overflow: hidden;
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(46,184,176,0.10) 0%, transparent 70%);
    pointer-events: none;
  }
  .page-hero-content { position: relative; z-index: 1; max-width: 700px; }
  .page-hero-heading {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 800;
    color: var(--white);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0.5rem 0 1.25rem;
  }
  .teal-text { color: var(--teal); }
  .page-hero-sub { font-size: 1.0625rem; color: var(--gray-mid); max-width: 560px; }
  .page-hero-sub strong { color: var(--teal); }

  .contact-section { background: var(--navy-dark); padding-top: 4rem; }
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 3rem;
    align-items: start;
    margin-bottom: 4rem;
  }
  @media (max-width: 900px) { .contact-layout { grid-template-columns: 1fr; } }

  .contact-form-heading {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.5rem;
  }
  .contact-form-sub { font-size: 0.9rem; color: var(--gray-mid); margin-bottom: 2rem; }

  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  @media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
  .form-group { display: flex; flex-direction: column; gap: 0.375rem; }
  .form-label {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--gray-light);
    letter-spacing: 0.02em;
  }
  .required { color: var(--teal); }
  .form-input {
    background: var(--navy-mid);
    border: 1.5px solid rgba(46,184,176,0.15);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    transition: border-color var(--transition), box-shadow var(--transition);
    outline: none;
    width: 100%;
    appearance: none;
  }
  .form-input::placeholder { color: #4a6a8a; }
  .form-input:focus {
    border-color: var(--teal);
    box-shadow: 0 0 0 3px rgba(46,184,176,0.12);
  }
  .form-select { cursor: pointer; }
  .form-select option { background: var(--navy-mid); }
  .form-textarea { resize: vertical; min-height: 100px; }
  .form-check-group { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .form-check {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--gray-light);
  }
  .form-checkbox {
    width: 18px;
    height: 18px;
    accent-color: var(--teal);
    cursor: pointer;
    flex-shrink: 0;
  }
  .form-submit { width: 100%; justify-content: center; }
  .form-note { font-size: 0.75rem; color: #4a6a8a; text-align: center; }

  .contact-info { display: flex; flex-direction: column; gap: 1.25rem; }
  .info-card { padding: 1.5rem; }
  .info-heading {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--teal);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }
  .info-items { display: flex; flex-direction: column; gap: 1.25rem; }
  .info-item { display: flex; gap: 0.875rem; align-items: flex-start; }
  .info-icon {
    width: 36px;
    height: 36px;
    background: #1b4542;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    flex-shrink: 0;
  }
  .info-content { display: flex; flex-direction: column; gap: 0.25rem; }
  .info-content strong { font-size: 0.875rem; font-weight: 600; color: var(--white); }
  .info-content a { font-size: 0.9rem; color: var(--teal); }
  .info-content span { font-size: 0.8125rem; color: var(--gray-mid); }
  .info-content address { font-size: 0.875rem; color: var(--gray-mid); }
  .directions-link {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--teal);
    margin-top: 0.25rem;
    transition: color var(--transition);
  }
  .directions-link:hover { color: var(--teal-light); }

  .hours-list { display: flex; flex-direction: column; }
  .hours-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .hours-item:last-child { border-bottom: none; }
  .hours-day { font-size: 0.8125rem; font-weight: 600; color: var(--gray-light); }
  .hours-time { font-size: 0.8rem; color: var(--teal); text-align: right; line-height: 1.5; }
  .hours-closed-label { font-size: 0.8rem; color: #4a6a8a; }

  .offer-reminder {
    background: linear-gradient(135deg, var(--teal), #1da89f);
    border-radius: var(--radius);
    padding: 1.25rem;
  }
  .offer-reminder-inner { display: flex; gap: 1rem; align-items: center; }
  .offer-reminder-badge {
    width: 52px;
    height: 52px;
    background: var(--navy-dark);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 800;
    color: var(--teal);
    flex-shrink: 0;
    letter-spacing: 0.05em;
  }
  .offer-reminder strong { display: block; color: var(--navy-dark); font-size: 0.9375rem; font-weight: 700; margin-bottom: 0.25rem; }
  .offer-reminder p { font-size: 0.8125rem; color: rgba(10,18,35,0.75); }

  .insurance-note { padding: 1.5rem; }
  .insurance-heading {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.625rem;
  }
  .insurance-note p { font-size: 0.8125rem; color: var(--gray-mid); line-height: 1.65; }

  /* Map */
  .map-section { padding-bottom: 0; }
  .map-heading {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 1rem;
  }
  .map-wrapper { position: relative; border-radius: var(--radius); overflow: hidden; border: 1px solid rgba(46,184,176,0.15); }
  .map-img { width: 100%; display: block; }
  .map-open-link {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    background: var(--navy-dark);
    border: 1px solid rgba(46,184,176,0.3);
    color: var(--teal);
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    transition: background var(--transition), border-color var(--transition);
  }
  .map-open-link:hover { background: var(--teal-muted); border-color: var(--teal); }
</style>
