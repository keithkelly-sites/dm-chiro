---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import frontofficeclouds from '../assets/images/frontofficeclouds.jpg';
import marcportrait from '../assets/images/marcportrait.jpg';
import deana from '../assets/images/deana2.jpg';
import service1 from '../assets/images/service1.jpg';
import service2 from '../assets/images/service2.jpg';
import service3 from '../assets/images/service3.jpg';
import service4 from '../assets/images/service4.jpg';
import award2021 from '../assets/images/bestchiro2021.png';
import award2022 from '../assets/images/best-of-2022.png';
import award2024 from '../assets/images/best-chiro-2024.jpg';
import award2025 from '../assets/images/best-chiro-2025.jpg';

// LocalBusiness JSON-LD for homepage
const homepageSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://dm-chiro.keithkelly.dev",
  "name": "D & M Chiropractic and Therapeutic Rehab, Inc.",
  "alternateName": "D&M Chiropractic",
  "description": "Award-winning chiropractic care in Upper St. Clair, PA. Dr. Marc & Dr. Deana Micucci. Free consultation. Most insurance accepted.",
  "url": "https://dm-chiro.keithkelly.dev",
  "telephone": "(412) 833-1101",
  "faxNumber": "(412) 833-1075",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "2589 Washington Road, Suite 410",
    "addressLocality": "Upper St. Clair",
    "addressRegion": "PA",
    "postalCode": "15241",
    "addressCountry": "US"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 40.3304, "longitude": -80.0534 },
  "openingHoursSpecification": [
    {"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Wednesday","Friday"],"opens":"08:00","closes":"12:30"},
    {"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Wednesday","Friday"],"opens":"14:00","closes":"18:00"}
  ]
};

const testimonials = [
  { quote: "Dr. Marc was just wonderful! He was able to explain everything in a clear way, and sincerely listened and showed he cared. I'm truly happy with my visit and trust that they will continue to help me on my quest toward wholistic health.", author: "Rosie C.", location: "Upper St. Clair, PA" },
  { quote: "I had neck and shoulder pain for over a year and saw my family doctor, two orthopedic specialists and a neurologist. Their solution was drugs. After only a few adjustments at D&M, my pain had diminished significantly. I no longer take any medications.", author: "Maribeth T.", location: "Upper St. Clair, PA" },
  { quote: "Dr.Marc and the staff are the best around! Always laughing and having fun when you are there — down to earth and Dr.Marc always takes care of any pain or discomfort I am dealing with!", author: "Victoria J.", location: "Upper St. Clair, PA" },
  { quote: "When I first saw Dr. Marc, I couldn't walk for over two weeks due to my injury. I was in excruciating pain. But I felt relief after my first appointment. Dr. Marc is MY HERO!", author: "Judy K.", location: "Upper St. Clair, PA" },
];

const conditions = [
  { icon: '🦴', label: 'Back Pain' },
  { icon: '🧠', label: 'Neck Pain' },
  { icon: '💢', label: 'Headaches' },
  { icon: '🚗', label: 'Auto Injuries' },
  { icon: '💿', label: 'Bulging Discs' },
  { icon: '🏗️', label: 'Work Injuries' },
  { icon: '🤸', label: 'Sports Injuries' },
  { icon: '🧒', label: 'Pediatric Care' },
];
---
<Layout
  title="Upper St. Clair Chiropractor | D & M Chiropractic and Therapeutic Rehab"
  description="Award-winning chiropractic care in Upper St. Clair, PA. Dr. Marc & Dr. Deana Micucci. Free consultation + free MRI review ($247 value). Most insurance accepted. Call (412) 833-1101."
  canonicalPath="/"
  page="home"
  schema={homepageSchema}
>
  <!-- Structured data: application/ld+json LocalBusiness schema passed to Layout via schema prop -->

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="hero" aria-label="Hero">
    <div class="hero-bg">
      <Image src={frontofficeclouds} alt="D&M Chiropractic welcoming office" class="hero-image" widths={[640, 1200, 1600]} loading="eager" />
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-content container">
      <div class="hero-text">
        <div class="reveal">
          <div class="hero-award-pill" aria-label="Award recognition">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--teal)" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            Best Pittsburgh Chiropractors — Expertise.com 2018–2023
          </div>
        </div>
        <h1 class="hero-heading reveal reveal-delay-1">
          Your Health<br/>
          <span class="teal-text">Is Our Focus</span>
        </h1>
        <p class="hero-sub reveal reveal-delay-2">
          Gentle, effective chiropractic care for pain relief and whole-body wellness. Trusted by Upper St. Clair families for over 15 years.
        </p>
        <div class="hero-actions reveal reveal-delay-3">
          <a href="/contact/" class="btn btn-primary">Free Consultation →</a>
          <a href="tel:+14128331101" class="btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1h3a2 2 0 012 1.72c.12.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L6.09 8.9a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.58 2.81.7A2 2 0 0122 16.92z"/></svg>
            (412) 833-1101
          </a>
        </div>
        <p class="hero-offer reveal reveal-delay-4">
          <strong style="color:var(--teal)">FREE Consultation + FREE MRI Review</strong> — a $247 value, at no charge
        </p>
      </div>

      <!-- Hero stats -->
      <div class="hero-stats reveal reveal-delay-3" aria-label="Practice highlights">
        <div class="stat-item">
          <div class="stat-num">15+</div>
          <div class="stat-label">Years Serving<br/>Upper St. Clair</div>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item">
          <div class="stat-num">5x</div>
          <div class="stat-label">Expertise.com<br/>Award Winner</div>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item">
          <div class="stat-num">98%</div>
          <div class="stat-label">Patient<br/>Satisfaction</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       QUICK TRUST BAR
       ============================================================ -->
  <section class="trust-bar" aria-label="Trust indicators">
    <div class="container trust-bar-inner">
      {[
        { icon: '⚡', text: 'No Wait Policy' },
        { icon: '🛡️', text: 'Most Insurance Accepted' },
        { icon: '💊', text: 'Drug-Free Relief' },
        { icon: '👨‍👩‍👧', text: 'Whole Family Care' },
        { icon: '📋', text: 'Free MRI Review' },
      ].map(item => (
        <div class="trust-item">
          <span class="trust-icon" aria-hidden="true">{item.icon}</span>
          <span class="trust-text">{item.text}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================================================
       FREE OFFER BANNER
       ============================================================ -->
  <section class="offer-banner" aria-label="Free consultation offer">
    <div class="container offer-banner-inner">
      <div class="offer-badge" aria-hidden="true">
        <span class="offer-value">$247</span>
        <span class="offer-value-label">value</span>
      </div>
      <div class="offer-text">
        <h2 class="offer-heading">Get a FREE Consultation + FREE MRI Review</h2>
        <p>New patients receive a complete consultation and MRI review at no charge. Discover what's causing your pain — without any commitment.</p>
      </div>
      <a href="/contact/" class="btn btn-primary offer-cta">Claim Your Free Visit →</a>
    </div>
  </section>

  <!-- ============================================================
       AWARDS
       ============================================================ -->
  <section class="section awards-section" aria-labelledby="awards-heading">
    <div class="container">
      <div class="awards-layout">
        <div class="awards-copy reveal">
          <span class="section-label">Recognition</span>
          <div class="teal-line"></div>
          <h2 class="section-heading" id="awards-heading">Pittsburgh's Most Trusted Chiropractors</h2>
          <p class="section-sub">
            Expertise.com evaluates thousands of chiropractors across Pittsburgh each year on qualifications, experience, patient reviews, and reputation. D&M Chiropractic has earned their Best Chiropractors distinction year after year.
          </p>
          <a href="/about/" class="btn btn-outline" style="margin-top:2rem;">Meet the Doctors →</a>
        </div>
        <div class="awards-badges reveal reveal-delay-2" aria-label="Award badges">
          <div class="award-grid">
            <figure class="award-item">
              <Image src={award2021} alt="Expertise.com Best Chiropractors Pittsburgh 2021" width={160} height={160} />
            </figure>
            <figure class="award-item">
              <Image src={award2022} alt="Expertise.com Best Chiropractors Pittsburgh 2022" width={160} height={160} />
            </figure>
            <figure class="award-item">
              <Image src={award2024} alt="Expertise.com Best Chiropractors Pittsburgh 2024" width={160} height={160} />
            </figure>
            <figure class="award-item">
              <Image src={award2025} alt="Expertise.com Best Chiropractors Pittsburgh 2025" width={160} height={160} />
            </figure>
          </div>
          <p class="award-caption">Expertise.com Best Chiropractors in Pittsburgh — Awarded 2018, 2020, 2021, 2022, 2023</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SERVICES PREVIEW
       ============================================================ -->
  <section class="section services-section" aria-labelledby="services-heading">
    <div class="container">
      <div class="section-header reveal" style="text-align:center;max-width:600px;margin:0 auto 3rem;">
        <span class="section-label">What We Treat</span>
        <div class="teal-line" style="margin:0.75rem auto 0;"></div>
        <h2 class="section-heading" id="services-heading">Comprehensive Care for the Whole Family</h2>
        <p class="section-sub" style="margin:0 auto;">From acute pain relief to long-term wellness, our individualized approach treats the cause — not just the symptoms.</p>
      </div>

      <div class="services-grid">
        {[
          { img: service1, alt: 'Chiropractic spinal adjustment', title: 'Chiropractic Care', desc: 'Precise spinal adjustments to correct subluxations, reduce pain, and restore nervous system function. The cornerstone of everything we do.', href: '/services/#chiropractic' },
          { img: service2, alt: 'Therapeutic rehabilitation exercise', title: 'Physical Therapy', desc: 'Therapeutic exercise, stretching, and physical modalities — ultrasound, e-stim, ice/heat — to accelerate healing and restore full mobility.', href: '/services/#therapy' },
          { img: service3, alt: 'Pediatric chiropractic care', title: 'Pediatric Chiropractic', desc: "Gentle, safe chiropractic care for infants and children. Most adult spinal problems begin in childhood. We treat patients from birth onward.", href: '/services/#pediatric' },
          { img: service4, alt: 'Nutritional counseling session', title: 'Nutritional Counseling', desc: 'Personalized diet and nutrition programs to reduce chronic disease risk and support your body\'s natural healing process from the inside out.', href: '/services/#nutrition' },
        ].map((svc, i) => (
          <article class={`service-card card reveal reveal-delay-${i + 1}`}>
            <div class="service-card-img">
              <Image src={svc.img} alt={svc.alt} widths={[400, 600]} class="service-img" />
            </div>
            <div class="service-card-body">
              <h3 class="service-card-title">{svc.title}</h3>
              <p class="service-card-desc">{svc.desc}</p>
              <a href={svc.href} class="service-card-link" aria-label={`Learn more about ${svc.title}`}>
                Learn more
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <div style="text-align:center;margin-top:3rem;" class="reveal">
        <a href="/services/" class="btn btn-outline">View All Services →</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CONDITIONS TREATED
       ============================================================ -->
  <section class="section conditions-section" aria-labelledby="conditions-heading">
    <div class="container">
      <div class="conditions-layout">
        <div class="conditions-copy reveal">
          <span class="section-label">Conditions</span>
          <div class="teal-line"></div>
          <h2 class="section-heading" id="conditions-heading">We Treat the Cause,<br/>Not the Symptom</h2>
          <p class="section-sub">
            Unlike approaches that mask pain with medication, chiropractic care corrects the structural cause of your discomfort — giving you lasting relief without drugs, surgery, or injections.
          </p>
          <a href="/contact/" class="btn btn-primary" style="margin-top:2rem;">Book Your Free Consult</a>
        </div>
        <div class="conditions-grid reveal reveal-delay-2" role="list" aria-label="Conditions treated">
          {conditions.map(c => (
            <div class="condition-chip" role="listitem">
              <span class="condition-icon" aria-hidden="true">{c.icon}</span>
              <span>{c.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       DOCTORS PREVIEW
       ============================================================ -->
  <section class="section doctors-section" aria-labelledby="doctors-heading">
    <div class="container">
      <div class="section-header reveal" style="text-align:center;max-width:580px;margin:0 auto 3.5rem;">
        <span class="section-label">The Doctors</span>
        <div class="teal-line" style="margin:0.75rem auto 0;"></div>
        <h2 class="section-heading" id="doctors-heading">A Husband & Wife Team Dedicated to Your Health</h2>
      </div>

      <div class="doctors-grid">
        <article class="doctor-card reveal">
          <div class="doctor-photo-wrap">
            <Image src={marcportrait} alt="Dr. Marc Micucci, Doctor of Chiropractic" class="doctor-photo" widths={[400, 600]} />
            <div class="doctor-photo-accent" aria-hidden="true"></div>
          </div>
          <div class="doctor-info">
            <h3 class="doctor-name">Dr. Marc Micucci, D.C.</h3>
            <p class="doctor-title">Doctor of Chiropractic</p>
            <p class="doctor-bio">Degree in exercise physiology from West Liberty State College. Doctorate from Life University in Marietta, GA. Specializes in corrective care — treating the cause of the problem, not just the symptoms. Over 15 years serving the Upper St. Clair community.</p>
            <ul class="doctor-creds" aria-label="Credentials">
              <li>Pennsylvania Chiropractic License</li>
              <li>Licensed, Adjunctive Procedures & Physical Therapy</li>
              <li>Member, Pennsylvania Chiropractic Association</li>
            </ul>
          </div>
        </article>

        <article class="doctor-card reveal reveal-delay-2">
          <div class="doctor-photo-wrap">
            <Image src={deana} alt="Dr. Deana Micucci, Doctor of Chiropractic" class="doctor-photo" widths={[400, 600]} />
            <div class="doctor-photo-accent" aria-hidden="true"></div>
          </div>
          <div class="doctor-info">
            <h3 class="doctor-name">Dr. Deana Micucci, D.C.</h3>
            <p class="doctor-title">Doctor of Chiropractic</p>
            <p class="doctor-bio">Undergraduate in Dental Hygiene from West Liberty State College. Doctorate from Life University, GA. Believes in the body's innate ability to heal from the inside out — focusing on natural approaches that uncover the underlying cause of dysfunction.</p>
            <ul class="doctor-creds" aria-label="Credentials">
              <li>Pennsylvania Chiropractic License</li>
              <li>Licensed, Adjunctive Procedures & Physical Therapy</li>
              <li>Member, Pennsylvania Chiropractic Association</li>
            </ul>
          </div>
        </article>
      </div>

      <div style="text-align:center;margin-top:3rem;" class="reveal">
        <a href="/about/" class="btn btn-outline">Full Doctor Profiles →</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       TESTIMONIALS
       ============================================================ -->
  <section class="section testimonials-section" aria-labelledby="testimonials-heading">
    <div class="container">
      <div class="section-header reveal" style="text-align:center;max-width:600px;margin:0 auto 3rem;">
        <span class="section-label">Patient Stories</span>
        <div class="teal-line" style="margin:0.75rem auto 0;"></div>
        <h2 class="section-heading" id="testimonials-heading">What Our Patients Say</h2>
        <p class="section-sub" style="margin:0 auto;">98% of our patients report satisfaction with their results and quality of care.</p>
      </div>

      <div class="testimonials-grid">
        {testimonials.map((t, i) => (
          <blockquote class={`testimonial-card card reveal reveal-delay-${(i % 3) + 1}`}>
            <div class="testimonial-quote-mark" aria-hidden="true">"</div>
            <p class="testimonial-text">{t.quote}</p>
            <footer class="testimonial-footer">
              <div class="testimonial-stars" aria-label="5 stars" role="img">
                {'★★★★★'}
              </div>
              <cite class="testimonial-author">
                <strong>{t.author}</strong>
                <span>{t.location}</span>
              </cite>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       FINAL CTA
       ============================================================ -->
  <section class="section final-cta-section" aria-labelledby="final-cta-heading">
    <div class="container final-cta-inner reveal">
      <div class="final-cta-content">
        <h2 class="section-heading" id="final-cta-heading">Ready to Live Pain-Free?</h2>
        <p class="section-sub">Take the first step toward lasting relief. Your free consultation includes a complete evaluation and free MRI review — at no charge to you.</p>
        <div class="final-cta-actions">
          <a href="/contact/" class="btn btn-primary">Claim Free Consultation →</a>
          <a href="tel:+14128331101" class="btn btn-outline">Call (412) 833-1101</a>
        </div>
        <p class="final-cta-sub">No obligation. Most insurance accepted. Same-day appointments available.</p>
      </div>
      <div class="final-cta-decoration" aria-hidden="true">
        <div class="cta-deco-ring ring-1"></div>
        <div class="cta-deco-ring ring-2"></div>
        <div class="cta-deco-ring ring-3"></div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: brightness(0.5) saturate(0.7);
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10, 18, 35, 0.92) 0%,
      rgba(15, 26, 48, 0.75) 50%,
      rgba(10, 18, 35, 0.6) 100%
    );
  }
  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 3rem;
    padding-top: 6rem;
    padding-bottom: 5rem;
    width: 100%;
  }
  .hero-text { max-width: 640px; }
  .hero-award-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(46,184,176,0.12);
    border: 1px solid rgba(46,184,176,0.35);
    color: var(--teal);
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    margin-bottom: 1.25rem;
  }
  .hero-heading {
    font-size: clamp(2.75rem, 7vw, 5rem);
    font-weight: 800;
    color: var(--white);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }
  .teal-text { color: var(--teal); }
  .hero-sub {
    font-size: 1.125rem;
    color: var(--gray-light);
    max-width: 520px;
    margin-bottom: 2rem;
    line-height: 1.75;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .hero-offer {
    font-size: 0.9rem;
    color: var(--gray-mid);
  }
  .hero-stats {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-self: flex-end;
    background: rgba(15, 26, 48, 0.75);
    border: 1px solid rgba(46,184,176,0.2);
    border-radius: var(--radius);
    padding: 1.5rem;
    backdrop-filter: blur(8px);
    min-width: 160px;
  }
  .stat-item { text-align: center; }
  .stat-num {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    color: var(--teal);
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .stat-label { font-size: 0.75rem; color: var(--gray-mid); line-height: 1.4; }
  .stat-divider { height: 1px; background: rgba(46,184,176,0.15); }

  @media (max-width: 900px) {
    .hero-stats { display: none; }
    .hero-content { padding-top: 5rem; padding-bottom: 4rem; }
  }
  @media (max-width: 600px) {
    .hero { min-height: 85vh; }
    .hero-heading { font-size: clamp(2.25rem, 10vw, 3rem); }
  }

  /* ---- Trust Bar ---- */
  .trust-bar {
    background: var(--navy-mid);
    border-bottom: 1px solid rgba(46,184,176,0.1);
    padding: 1.25rem 1.5rem;
  }
  .trust-bar-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
  }
  .trust-icon { font-size: 1rem; }
  .trust-text {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--gray-light);
    letter-spacing: 0.01em;
  }

  /* ---- Offer Banner ---- */
  .offer-banner {
    background: linear-gradient(135deg, var(--teal) 0%, #1da89f 100%);
    padding: 2.5rem 1.5rem;
  }
  .offer-banner-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .offer-badge {
    width: 80px;
    height: 80px;
    background: var(--navy-dark);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .offer-value {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--teal);
    line-height: 1;
  }
  .offer-value-label { font-size: 0.65rem; color: var(--gray-mid); letter-spacing: 0.05em; }
  .offer-text { flex: 1; min-width: 240px; }
  .offer-heading {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 800;
    color: var(--navy-dark);
    margin-bottom: 0.375rem;
  }
  .offer-text p { font-size: 0.9rem; color: rgba(10,18,35,0.75); }
  .offer-cta {
    background: var(--navy-dark) !important;
    color: var(--teal) !important;
    flex-shrink: 0;
  }
  .offer-cta:hover {
