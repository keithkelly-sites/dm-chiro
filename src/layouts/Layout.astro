---
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  schema?: object;
  page?: string;
}

const {
  title,
  description = 'D & M Chiropractic and Therapeutic Rehab — Upper St. Clair, PA. Award-winning chiropractic care from Dr. Marc & Dr. Deana Micucci. Free consultation. Most insurance accepted.',
  canonicalPath = '',
  ogImage = '/images/frontofficeclouds.jpg',
  schema,
  page = '',
} = Astro.props;

const siteUrl = 'https://dm-chiro.keithkelly.dev';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = `${siteUrl}${ogImage}`;

const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": siteUrl,
  "name": "D & M Chiropractic and Therapeutic Rehab, Inc.",
  "alternateName": "D&M Chiropractic",
  "description": description,
  "url": siteUrl,
  "telephone": "(412) 833-1101",
  "faxNumber": "(412) 833-1075",
  "priceRange": "$$",
  "currenciesAccepted": "USD",
  "paymentAccepted": "Cash, Credit Card, Insurance",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "2589 Washington Road, Suite 410",
    "addressLocality": "Upper St. Clair",
    "addressRegion": "PA",
    "postalCode": "15241",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.3304,
    "longitude": -80.0534
  },
  "openingHoursSpecification": [
    {"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Wednesday","Friday"],"opens":"08:00","closes":"12:30"},
    {"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Wednesday","Friday"],"opens":"14:00","closes":"18:00"}
  ],
  "medicalSpecialty": "Chiropractic",
  "hasMap": "https://maps.google.com/?q=2589+Washington+Road+Suite+410+Upper+St+Clair+PA+15241",
  "sameAs": [
    "https://www.facebook.com/dmchiro",
    "https://twitter.com/dmchiro",
    "https://www.instagram.com/dmchiro"
  ],
  "award": [
    "Expertise.com Best Chiropractors in Pittsburgh 2018",
    "Expertise.com Best Chiropractors in Pittsburgh 2020",
    "Expertise.com Best Chiropractors in Pittsburgh 2021",
    "Expertise.com Best Chiropractors in Pittsburgh 2022",
    "Expertise.com Best Chiropractors in Pittsburgh 2023"
  ]
};

const finalSchema = schema ?? defaultSchema;
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services/', label: 'Services' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="D & M Chiropractic" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <title>{title}</title>
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body" preload />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(finalSchema)} />
    <ClientRouter />
  </head>
  <body>
    <!-- Add js-loaded class immediately for reveal animations -->
    <script is:inline>document.documentElement.classList.add('js-loaded');</script>
    <a href="#main-content" class="skip-to-content">Skip to main content</a>

    <!-- ======================================================
         HEADER
         ====================================================== -->
    <header class="site-header" id="site-header">
      <div class="header-inner">
        <a href="/" class="header-logo" aria-label="D&M Chiropractic — Home">
          <div class="header-logo-mark" aria-hidden="true">D&M</div>
          <div class="header-logo-text">
            <span class="logo-name">D&M Chiropractic</span>
            <span class="logo-sub">Therapeutic Rehab</span>
          </div>
        </a>

        <nav class="site-nav" aria-label="Main navigation">
          {navLinks.map(link => (
            <a
              href={link.href}
              aria-current={page === link.label.toLowerCase() ? 'page' : undefined}
            >{link.label}</a>
          ))}
        </nav>

        <a href="/contact/" class="header-cta">Free Consultation</a>

        <button
          class="mobile-menu-btn"
          aria-expanded="false"
          aria-controls="mobile-nav"
          aria-label="Open navigation menu"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            aria-current={page === link.label.toLowerCase() ? 'page' : undefined}
          >{link.label}</a>
        ))}
        <a href="/contact/" class="mobile-cta">Free Consultation →</a>
      </nav>
    </header>

    <!-- ======================================================
         MAIN
         ====================================================== -->
    <main id="main-content">
      <slot />
    </main>

    <!-- ======================================================
         FOOTER
         ====================================================== -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-grid">
          <!-- Brand -->
          <div class="footer-brand">
            <div class="footer-logo-mark" aria-hidden="true">D&M</div>
            <p>Gentle, effective chiropractic care for the whole family in Upper St. Clair, PA. Award-winning doctors. Most insurance accepted.</p>
            <div class="footer-social" aria-label="Social media links">
              <a href="#" aria-label="Facebook" rel="noopener noreferrer">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
              </a>
              <a href="#" aria-label="Twitter / X" rel="noopener noreferrer">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
              </a>
              <a href="#" aria-label="Instagram" rel="noopener noreferrer">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
              </a>
              <a href="#" aria-label="Google Maps" rel="noopener noreferrer">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              </a>
            </div>
          </div>

          <!-- Quick Links -->
          <div class="footer-col">
            <h3 class="footer-col-heading">Navigation</h3>
            <ul>
              <li><a href="/">Home</a></li>
              <li><a href="/services/">Services</a></li>
              <li><a href="/about/">About Us</a></li>
              <li><a href="/contact/">Contact</a></li>
            </ul>
          </div>

          <!-- Services -->
          <div class="footer-col">
            <h3 class="footer-col-heading">Services</h3>
            <ul>
              <li><a href="/services/#chiropractic">Chiropractic Care</a></li>
              <li><a href="/services/#pediatric">Pediatric Chiro</a></li>
              <li><a href="/services/#therapy">Physical Therapy</a></li>
              <li><a href="/services/#nutrition">Nutritional Counseling</a></li>
              <li><a href="/services/#massage">Massage Therapy</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div class="footer-col">
            <h3 class="footer-col-heading">Contact</h3>
            <div class="footer-contact-info">
              <div class="contact-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-top:2px;flex-shrink:0;color:var(--teal)" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1h3a2 2 0 012 1.72c.12.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L6.09 8.9a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.58 2.81.7A2 2 0 0122 16.92z"/></svg>
                <div><a href="tel:+14128331101" style="color:var(--gray-light)">(412) 833-1101</a></div>
              </div>
              <div class="contact-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-top:2px;flex-shrink:0;color:var(--teal)" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <div>2589 Washington Road<br/>Suite 410<br/>Upper St. Clair, PA 15241</div>
              </div>
              <div class="contact-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-top:4px;flex-shrink:0;color:var(--teal)" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <div>
                  <ul class="footer-hours-list">
                    <li><span class="day">Mon / Wed / Fri</span><span>8am–12:30p, 2–6pm</span></li>
                    <li><span class="day">Tue / Thu</span><span class="closed">Closed</span></li>
                    <li><span class="day">Sat / Sun</span><span class="closed">Closed</span></li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Footer bottom -->
        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} D & M Chiropractic and Therapeutic Rehab, Inc. All rights reserved.</p>
          <div class="footer-awards-strip" aria-label="Expertise.com award years">
            <span style="font-size:0.7rem;color:var(--gray-mid)">Best Pittsburgh Chiropractors:</span>
            {['2018','2020','2021','2022','2023'].map(y => (
              <span class="award-tag">{y}</span>
            ))}
          </div>
        </div>
      </div>
    </footer>

    <script>
      // Header scroll shadow
      const header = document.getElementById('site-header');
      window.addEventListener('scroll', () => {
        header?.classList.toggle('scrolled', window.scrollY > 20);
      }, { passive: true });

      // Mobile menu
      const btn = document.querySelector('.mobile-menu-btn') as HTMLButtonElement | null;
      const nav = document.getElementById('mobile-nav');
      if (btn && nav) {
        btn.addEventListener('click', () => {
          const open = nav.classList.toggle('open');
          btn.setAttribute('aria-expanded', String(open));
          btn.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
        });
        // Close on outside click
        document.addEventListener('click', (e) => {
          if (!btn.contains(e.target as Node) && !nav.contains(e.target as Node)) {
            nav.classList.remove('open');
            btn.setAttribute('aria-expanded', 'false');
          }
        });
      }

      // Reveal on scroll
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -50px 0px' }
      );
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>

    <!-- Re-init after view transitions -->
    <script>
      document.addEventListener('astro:page-load', () => {
        const header = document.getElementById('site-header');
        window.addEventListener('scroll', () => {
          header?.classList.toggle('scrolled', window.scrollY > 20);
        }, { passive: true });
        document.querySelectorAll('.reveal').forEach(el => {
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach(entry => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('visible');
                  observer.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.12, rootMargin: '0px 0px -50px 0px' }
          );
          observer.observe(el);
        });
      });
    </script>
  </body>
</html>
